// =======================================
// Vehicle Service Schema (Uber-like)
// Handles: Vehicles, VehicleImages, Contracts, MOT, Insurance, PCO
// =======================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InspectionType {
  MOT
  SAFETY
  EMISSIONS
  ANNUAL
  TFL
  PRIVATE_HIRE
  MECHANICAL
}

enum DocumentStatus {
  ACCEPTED
  REJECTED
  PENDING
}

enum VehicleDocumentKind {
  INSPECTION
  INSURANCE
  PCO_DOCUMENT
  PERMISSION_LETTER
  SCHEDULE
  LOG_BOOK_V5
}

enum VehicleDocumentChangeRequestStatus {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
  CANCELLED
}

// ==========================
// VEHICLES
// ==========================

model Vehicle {
  id       String @id @default(uuid())
  driverId String // references driverId from User Service

  make        String
  model       String
  year        Int
  color       String?
  plateNumber String  @unique

  isApproved Boolean @default(false) // admin approval
  isActive   Boolean @default(true) // currently in use

  permission_letter Json?
  vehicle_schedule  Json?

  images                    VehicleImage[]
  // Mandatory before admin can approve the vehicle (each group needs ≥1 ACCEPTED row).
  logBookV5                 LogBookV5[]
  inspections               VehicleInspection[]
  insurances                VehicleInsurance[]
  pcoDocs                   VehiclePcoDocument[]
  // Optional until requiestOptionalDocuments is true; then both groups become mandatory.
  permissionLetters         PermissionLetter[]
  vehicleSchedules          VehicleSchedule[]
  // Admin flag: when true, driver must upload and get permission letter + schedule accepted.
  requiestOptionalDocuments Boolean              @default(false)

  documentChangeRequests VehicleDocumentChangeRequest[]
  changeRequests         VehicleChangeRequest[]
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
}

// ==========================
// VEHICLE IMAGES
// ==========================

model VehicleImage {
  id        String @id @default(uuid())
  vehicleId String
  image     Json
  type      String // front, back, interior, plate, registration, other

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model LogBookV5 {
  id             String         @id @default(uuid())
  vehicleId      String
  document       Json
  status         DocumentStatus @default(PENDING)
  rejectedReason String?
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([vehicleId, status])
}

model VehicleInspection {
  id             String          @id @default(uuid())
  vehicleId      String
  inspectionType InspectionType? // MOT, Safety, Emissions, etc.
  inspectionDate DateTime?
  expiryDate     DateTime?
  document       Json?
  status         DocumentStatus  @default(PENDING)
  rejectedReason String?
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model VehicleInsurance {
  id             String         @id @default(uuid())
  vehicleId      String
  provider       String?
  policyNumber   String?
  startDate      DateTime?
  endDate        DateTime?
  document       Json?
  status         DocumentStatus @default(PENDING)
  rejectedReason String?
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VehiclePcoDocument {
  id             String         @id @default(uuid())
  vehicleId      String
  badgeNumber    String?
  issueDate      DateTime?
  expiryDate     DateTime?
  document       Json? // PCO badge scan or registration document
  status         DocumentStatus @default(PENDING)
  rejectedReason String?
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PermissionLetter {
  id             String         @id @default(uuid())
  vehicleId      String
  document       Json?
  status         DocumentStatus @default(PENDING)
  rejectedReason String?
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VehicleSchedule {
  id             String         @id @default(uuid())
  vehicleId      String
  document       Json?
  status         DocumentStatus @default(PENDING)
  rejectedReason String?
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VehicleDocumentChangeRequest {
  id String @id @default(uuid())

  driverId         String
  vehicleId        String
  targetType       VehicleDocumentKind
  targetDocumentId String

  status VehicleDocumentChangeRequestStatus @default(PENDING_REVIEW)

  /// Proposed document snapshot (editable fields only; shape depends on targetType).
  payload     Json
  driver_note String?

  rejected_reason String?
  reviewed_by_id  String?
  reviewed_at     DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId, status])
  @@index([vehicleId, status])
  @@index([targetType, targetDocumentId, status])
}

/// Driver-proposed updates to an approved vehicle profile (make, model, plate, uploads, etc.).
model VehicleChangeRequest {
  id String @id @default(uuid())

  driverId  String
  vehicleId String

  status VehicleDocumentChangeRequestStatus @default(PENDING_REVIEW)

  /// Proposed vehicle snapshot (editable driver fields only).
  payload     Json
  driver_note String?

  rejected_reason String?
  reviewed_by_id  String?
  reviewed_at     DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId, status])
  @@index([vehicleId, status])
}
